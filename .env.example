# Copy to .env, then edit. docker compose loads it automatically.
#
# Defaults below are tuned for local development with agents:
#   - the host port binds only to 127.0.0.1 (loopback)
#   - the server is unauthenticated, so loopback is the safe default
#
# Henka is unauthenticated and applies edits in place to the mounted repos.
# For any deployment beyond your laptop, keep HENKA_PUBLISH_ADDR on loopback and
# put a reverse proxy that terminates auth in front. Never set
# HENKA_PUBLISH_ADDR=0.0.0.0 on an untrusted network. See docs/deploying.md.

# REQUIRED for the `henka` service. Host directory holding the working copies you
# want to operate on; it is mounted read-write at /workspaces. Register each as a
# project by its in-container path, e.g. /workspaces/my-service. A repository's
# git worktrees / jj workspaces can live as sibling dirs here — Henka groups them
# by repository. Compose doesn't expand `~`, so use ${HOME} or an absolute path.
HENKA_WORKSPACES_DIR=/path/to/your/workspaces

# Pin a specific release image instead of :latest.
# HENKA_IMAGE=ghcr.io/martint/henka:1.2.3

# Persistent data directory (project registry + warm per-repository indexes).
# Default is a managed Docker volume named `henka-data`; set this to a host path
# to bind-mount instead. Compose doesn't expand `~`, so use ${HOME} or an
# absolute path.
# HENKA_DATA_DIR=${HOME}/henka

# Host interface Docker publishes the port on (the container always binds
# 0.0.0.0 internally; this only controls the host side). Defaults to 127.0.0.1
# (loopback only). Change to 0.0.0.0 ONLY behind an authenticating reverse proxy
# or on a trusted network — Henka performs no authentication, so anyone who can
# reach the port can edit your repositories.
# HENKA_PUBLISH_ADDR=0.0.0.0

# Host port. Default 8181.
# HENKA_PUBLISH_PORT=8181

# Log verbosity (tracing env-filter syntax). Default: info.
# HENKA_LOG=info,henka=debug

# Hostname(s) to add to MCP's Host-header allowlist (DNS-rebinding guard).
# Default allows localhost / 127.0.0.1 / ::1 only, which is fine for same-host
# access but blocks a client that reaches the server under another name (e.g. a
# containerized client connecting via host.docker.internal, or Henka behind a
# reverse proxy). Space-separated for multiple values.
# HENKA_MCP_ALLOWED_HOST=host.docker.internal
